<nav class="border-b mb-4 px-4 py-2 flex gap-4">
  <%= for item <- @nav do %>
    <a href="#" class="font-medium"><%= item.name %></a>
  <% end %>
</nav>
<main class="p-8">
  <h1 class="text-2xl font-semibold"><%= @tenant.name %></h1>
  <p class="text-gray-500">Atrium tenant <%= @tenant.slug %> — Phase 0a skeleton</p>
</main>
